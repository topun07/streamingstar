option_settings:
  # Increase the Elastic Load Balancer (ELB) timeout to 180 seconds (3 minutes)
  # This is the primary cause of 504 errors.
  aws:elasticbeanstalk:environment:
    LoadBalancerHTTPTimeout: 180

  # For Amazon Linux 2023, increase the internal Nginx proxy timeout
  aws:elasticbeanstalk:container:nodejs:
    ProxyServer: nginx
  aws:elasticbeanstalk:environment:
    ProxyTimeout: 180